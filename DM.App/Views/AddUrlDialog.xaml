<Window x:Class="DM.App.Views.AddUrlDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Thêm URL tải" Width="540" SizeToContent="Height"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{StaticResource Bg}" FontFamily="Segoe UI">
    <Border Margin="16" Background="{StaticResource Card}" CornerRadius="12"
            BorderBrush="{StaticResource Line}" BorderThickness="1" Padding="18">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="URL" FontWeight="SemiBold" Foreground="{StaticResource TextSecondary}" Margin="2,0,0,5"/>
            <DockPanel Grid.Row="1">
                <Button x:Name="ProbeButton" Content="Phân tích" Style="{StaticResource GhostButton}"
                        DockPanel.Dock="Right" Margin="8,0,0,0" Click="OnProbeClick"/>
                <TextBox x:Name="UrlBox" Style="{StaticResource InputBox}"/>
            </DockPanel>

            <TextBlock Text="Tên file" Grid.Row="2" FontWeight="SemiBold"
                       Foreground="{StaticResource TextSecondary}" Margin="2,12,0,5"/>
            <TextBox x:Name="FileNameBox" Grid.Row="3" Style="{StaticResource InputBox}"/>

            <TextBlock x:Name="InfoText" Grid.Row="4" Margin="2,12,0,4" MinHeight="20"
                       Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap" VerticalAlignment="Top"/>

            <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                <Button Content="Hủy" Style="{StaticResource GhostButton}" Width="90" IsCancel="True"/>
                <Button Content="Tải" Style="{StaticResource PrimaryButton}" Width="90" Margin="8,0,0,0"
                        IsDefault="True" Click="OnOkClick"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
